generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  superadmin
  admin
  user
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  googleId      String?   @unique
  avatarUrl     String?
  role          Role      @default(user)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[] @relation("ActorAuditLogs")
  allowedEmails AllowedEmail[] @relation("AllowedEmailCreator")
  invitations   AuthInvitation[] @relation("AuthInvitationCreator")
  playerRanking PlayerRanking?
  matchesCreated Match[] @relation("MatchCreator")
  matchesWon     Match[] @relation("MatchWinner")
  matchesLost    Match[] @relation("MatchLoser")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  targetUserId String?
  action       String
  metadata     Json?
  createdAt    DateTime @default(now())

  actor User? @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
}

model AllowedEmail {
  id              String   @id @default(cuid())
  email           String   @unique
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  createdBy User? @relation("AllowedEmailCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
}

model AuthInvitation {
  id              String    @id @default(cuid())
  tokenHash       String    @unique
  expiresAt       DateTime
  usedAt          DateTime?
  usedByEmail     String?
  createdByUserId String?
  createdAt       DateTime  @default(now())

  createdBy User? @relation("AuthInvitationCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
  @@index([expiresAt])
  @@index([usedAt])
}

model PlayerRanking {
  id            String   @id @default(cuid())
  userId        String   @unique
  elo           Int      @default(1000)
  wins          Int      @default(0)
  total_matches Int      @default(0)
  winRate       Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([elo])
  @@index([wins])
}

model RankLevel {
  id         String @id @default(cuid())
  name       String @unique
  minElo     Int    @unique
  iconImgKey String

  @@index([minElo])
}

model Match {
  id           String   @id @default(cuid())
  winnerUserId String
  loserUserId  String
  createdById  String
  kFactor      Int
  winnerOldElo Int
  winnerNewElo Int
  loserOldElo  Int
  loserNewElo  Int
  createdAt    DateTime @default(now())
  finishedAt   DateTime @default(now())

  winner   User @relation("MatchWinner", fields: [winnerUserId], references: [id], onDelete: Restrict)
  loser    User @relation("MatchLoser", fields: [loserUserId], references: [id], onDelete: Restrict)
  createdBy User @relation("MatchCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([winnerUserId])
  @@index([loserUserId])
  @@index([createdById])
  @@index([createdAt])
}
