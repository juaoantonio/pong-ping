generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  superadmin
  admin
  user
}

enum MatchHistoryKind {
  match
  rollback
}

model User {
  id                     String                    @id @default(cuid())
  name                   String?
  email                  String?                   @unique
  emailVerified          DateTime?
  image                  String?
  googleId               String?                   @unique
  avatarUrl              String?
  role                   Role                      @default(user)
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @default(now()) @updatedAt
  accounts               Account[]
  sessions               Session[]
  auditLogs              AuditLog[]                @relation("ActorAuditLogs")
  allowedEmails          AllowedEmail[]            @relation("AllowedEmailCreator")
  invitations            AuthInvitation[]          @relation("AuthInvitationCreator")
  playerRanking          PlayerRanking?
  matchHistoriesCreated  MatchHistory[]            @relation("MatchHistoryCreator")
  matchHistoriesWon      MatchHistory[]            @relation("MatchHistoryWinner")
  matchHistoriesLost     MatchHistory[]            @relation("MatchHistoryLoser")
  roomMemberships        PingPongRoomParticipant[]
  roomInvitationsCreated PingPongRoomInvitation[]  @relation("RoomInvitationCreator")
  roomsCreated           PingPongRoom[]            @relation("RoomCreator")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  targetUserId String?
  action       String
  metadata     Json?
  createdAt    DateTime @default(now())

  actor User? @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
}

model AllowedEmail {
  id              String   @id @default(cuid())
  email           String   @unique
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  createdBy User? @relation("AllowedEmailCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
}

model AuthInvitation {
  id              String    @id @default(cuid())
  tokenHash       String    @unique
  expiresAt       DateTime
  oneTimeUse      Boolean   @default(true)
  usedAt          DateTime?
  usedByEmail     String?
  createdByUserId String?
  createdAt       DateTime  @default(now())

  createdBy User? @relation("AuthInvitationCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
  @@index([expiresAt])
  @@index([usedAt])
}

model PlayerRanking {
  id            String   @id @default(cuid())
  userId        String   @unique
  elo           Int      @default(1000)
  wins          Int      @default(0)
  total_matches Int      @default(0)
  winRate       Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([elo])
  @@index([wins])
}

model RankLevel {
  id         String @id @default(cuid())
  name       String @unique
  minElo     Int    @unique
  iconImgKey String

  @@index([minElo])
}

model MatchHistory {
  id               String           @id @default(cuid())
  roomId           String?
  winnerId         String
  loserId          String
  createdById      String
  rollbackOfId     String?          @unique
  kind             MatchHistoryKind @default(match)
  kFactor          Int
  winnerOldElo     Int
  winnerNewElo     Int
  winnerDiffPoints Int
  loserOldElo      Int
  loserNewElo      Int
  loserDiffPoints  Int
  createdAt        DateTime         @default(now())
  finishedAt       DateTime         @default(now())

  room       PingPongRoom?  @relation(fields: [roomId], references: [id], onDelete: SetNull)
  winner     User           @relation("MatchHistoryWinner", fields: [winnerId], references: [id], onDelete: Restrict)
  loser      User           @relation("MatchHistoryLoser", fields: [loserId], references: [id], onDelete: Restrict)
  createdBy  User           @relation("MatchHistoryCreator", fields: [createdById], references: [id], onDelete: Restrict)
  rollbackOf MatchHistory?  @relation("MatchHistoryRollback", fields: [rollbackOfId], references: [id], onDelete: Restrict)
  rollbacks  MatchHistory[] @relation("MatchHistoryRollback")

  @@index([roomId])
  @@index([winnerId])
  @@index([loserId])
  @@index([createdById])
  @@index([kind])
  @@index([createdAt])
}

model PingPongRoom {
  id             String                    @id @default(cuid())
  name           String
  createdById    String
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @default(now()) @updatedAt
  deletedAt      DateTime?
  createdBy      User                      @relation("RoomCreator", fields: [createdById], references: [id], onDelete: Restrict)
  invitations    PingPongRoomInvitation[]
  matchHistories MatchHistory[]
  participants   PingPongRoomParticipant[]

  @@index([createdById])
  @@index([createdAt])
}

model PingPongRoomParticipant {
  id            String       @id @default(cuid())
  roomId        String
  userId        String
  queuePosition Int
  joinedAt      DateTime     @default(now())
  room          PingPongRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@unique([roomId, queuePosition])
  @@index([roomId])
  @@index([userId])
}

model PingPongRoomInvitation {
  id           String       @id @default(cuid())
  roomId       String
  token        String       @unique
  createdById  String
  expiresAt    DateTime
  oneTimeUse   Boolean      @default(false)
  usedAt       DateTime?
  usedByUserId String?
  createdAt    DateTime     @default(now())
  room         PingPongRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("RoomInvitationCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([roomId])
  @@index([createdById])
  @@index([expiresAt])
  @@index([usedAt])
}
