{
  "name": "pong-ping",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:be": "pnpm --filter @pong-ping/backend start:dev",
    "dev:fe": "pnpm --filter @pong-ping/frontend dev",
    "build": "pnpm -r build",
    "build:be": "pnpm --filter @pong-ping/backend build",
    "build:fe": "pnpm --filter @pong-ping/frontend build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:be": "pnpm --filter @pong-ping/backend test",
    "test:fe": "pnpm --filter @pong-ping/frontend test",
    "test:e2e": "pnpm --filter @pong-ping/backend test:e2e",
    "migration:run": "pnpm --filter @pong-ping/backend migration:run",
    "migration:generate": "pnpm --filter @pong-ping/backend migration:generate"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "typescript": "^5.9.3"
  }
}
